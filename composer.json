{
  "name": "jdwx/app",
  "description": "A trivial PHP framework for command line apps.",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "JDWX\\App\\": "src/"
    }
  },
  "require": {
    "php": ">=8.3.0",
    "jdwx/args": "^2.0",
    "jdwx/log": "^2.0",
    "psr/log": "^3.0",
    "ext-posix": "*"
  },
  "suggest": {
    "ext-readline": "For interactive applications."
  },
  "require-dev": {
    "jetbrains/phpstorm-attributes": "^1.2",
    "phan/phan": "^v6",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^12.5"
  },
  "scripts": {
    "phan": "PHAN_ALLOW_XDEBUG=1 php -d xdebug.mode=off vendor/bin/phan --analyze-twice",
    "phpstan": "phpstan",
    "phpunit": "vendor/bin/phpunit tests"
  }
}
